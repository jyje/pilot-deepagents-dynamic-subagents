# NVIDIA NIM API Configuration
# Get your API key at: https://build.nvidia.com
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Base URL — leave empty for NVIDIA API Catalog (default)
# Self-hosted NIM (local):  http://0.0.0.0:8000
NVIDIA_BASE_URL=

# Model Configuration
# Main orchestrator model
MAIN_MODEL=meta/llama-3.3-70b-instruct
# Researcher subagent model (knowledge-intensive tasks)
RESEARCHER_MODEL=nvidia/nemotron-3-super-120b-a12b
# Reviewer subagent model (validation and critique)
REVIEWER_MODEL=meta/llama-3.1-8b-instruct

# LangSmith Tracing (optional — recommended for LangGraph Studio)
# Get your API key at: https://smith.langchain.com
LANGSMITH_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=pilot-deepagents-dynamic-subagents
